{
  "providers": {
    "anthropic": {
      "label": "Anthropic (Direct API)",
      "envVars": {
        "always": [
          { "key": "ANTHROPIC_API_KEY", "desc": "Anthropic API key", "required": true },
          { "key": "ANTHROPIC_MODEL", "desc": "Model ID for LLM calls", "required": true },
          { "key": "ANTHROPIC_SMALL_FAST_MODEL", "desc": "Small/fast model for triage", "required": false }
        ]
      },
      "models": {
        "sonnet": "claude-sonnet-4-6",
        "opus": "claude-opus-4-6",
        "haiku": "claude-haiku-4-5",
        "sonnet-3.5": "claude-3-5-sonnet-20241022"
      },
      "defaultModel": "sonnet",
      "defaultSmallModel": "claude-haiku-4-5",
      "pinVars": {
        "opus": "ANTHROPIC_DEFAULT_OPUS_MODEL",
        "sonnet": "ANTHROPIC_DEFAULT_SONNET_MODEL",
        "haiku": "ANTHROPIC_DEFAULT_HAIKU_MODEL"
      }
    },
    "bedrock": {
      "label": "Amazon Bedrock",
      "envVars": {
        "always": [
          { "key": "CLAUDE_CODE_USE_BEDROCK", "desc": "Enable Bedrock mode", "required": true, "value": "1" },
          { "key": "CLAUDE_PROVIDER", "desc": "LLM provider type", "required": true, "value": "bedrock" },
          { "key": "AWS_REGION", "desc": "AWS region for Bedrock", "required": true, "alts": ["AWS_DEFAULT_REGION"] },
          { "key": "ANTHROPIC_MODEL", "desc": "Bedrock model ID", "required": true },
          { "key": "ANTHROPIC_SMALL_FAST_MODEL", "desc": "Small/fast model for triage", "required": false }
        ],
        "authMethods": {
          "iam-role": {
            "label": "EC2 instance profile or ECS task role (recommended)",
            "envVars": []
          },
          "access-keys": {
            "label": "AWS access key + secret key (AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY)",
            "envVars": [
              { "key": "AWS_ACCESS_KEY_ID", "desc": "AWS access key ID", "required": true, "secret": true },
              { "key": "AWS_SECRET_ACCESS_KEY", "desc": "AWS secret access key", "required": true, "secret": true }
            ]
          },
          "profile": {
            "label": "Named AWS profile (~/.aws/credentials or SSO)",
            "envVars": [
              { "key": "AWS_PROFILE", "desc": "AWS profile name", "required": true }
            ]
          },
          "api-keys": {
            "label": "Bedrock API keys (from AWS console → Bedrock → API keys)",
            "envVars": [
              { "key": "AWS_BEARER_TOKEN_BEDROCK", "desc": "Bedrock API key", "required": true, "secret": true }
            ]
          },
          "sso": {
            "label": "AWS SSO / Identity Center",
            "envVars": [
              { "key": "AWS_PROFILE", "desc": "AWS SSO profile name", "required": true }
            ]
          }
        },
        "defaultAuthMethod": "iam-role"
      },
      "models": {
        "sonnet": "us.anthropic.claude-sonnet-4-6",
        "opus": "us.anthropic.claude-opus-4-6-v1",
        "haiku": "us.anthropic.claude-haiku-4-5-20251001-v1:0",
        "sonnet-3.5": "us.anthropic.claude-3-5-sonnet-20241022-v2:0"
      },
      "defaultModel": "sonnet",
      "defaultSmallModel": "us.anthropic.claude-haiku-4-5-20251001-v1:0",
      "pinVars": {
        "opus": "ANTHROPIC_DEFAULT_OPUS_MODEL",
        "sonnet": "ANTHROPIC_DEFAULT_SONNET_MODEL",
        "haiku": "ANTHROPIC_DEFAULT_HAIKU_MODEL"
      }
    },
    "litellm": {
      "label": "LiteLLM Proxy",
      "envVars": {
        "always": [
          { "key": "ANTHROPIC_BASE_URL", "desc": "LiteLLM proxy URL", "required": true },
          { "key": "ANTHROPIC_MODEL", "desc": "Model ID", "required": true },
          { "key": "ANTHROPIC_API_KEY", "desc": "LiteLLM proxy API key (if proxy requires auth)", "required": false }
        ]
      },
      "models": {
        "sonnet": "claude-sonnet-4-6",
        "opus": "claude-opus-4-6",
        "haiku": "claude-haiku-4-5"
      },
      "defaultModel": "sonnet",
      "defaultSmallModel": "claude-haiku-4-5"
    }
  },
  "commonEnvVars": [
  ],
  "gitProviders": {
    "github": {
      "label": "GitHub",
      "envVars": [
        { "key": "GITHUB_TOKEN", "desc": "GitHub personal access token", "required": true, "secret": true, "alts": ["GITHUB_PAT", "GH_TOKEN"] }
      ],
      "hint": "Create at https://github.com/settings/tokens (scopes: repo)"
    },
    "codecommit": {
      "label": "AWS CodeCommit",
      "envVars": [
        { "key": "AWS_REGION", "desc": "AWS region for CodeCommit", "required": true, "alts": ["AWS_DEFAULT_REGION"] }
      ],
      "authNote": "Uses IAM credentials (instance profile, AWS CLI config, or access keys). Ensure git-remote-codecommit is installed: pip install git-remote-codecommit",
      "hint": "Requires AWS CLI configured + git-remote-codecommit helper"
    },
    "gitlab": {
      "label": "GitLab",
      "envVars": [
        { "key": "GITLAB_TOKEN", "desc": "GitLab personal/project access token", "required": true, "secret": true },
        { "key": "GITLAB_URL", "desc": "GitLab instance URL (default: https://gitlab.com)", "required": false }
      ],
      "hint": "Create at Settings → Access Tokens (scopes: read_repository, read_api)"
    },
    "azure": {
      "label": "Azure DevOps",
      "envVars": [
        { "key": "AZURE_DEVOPS_PAT", "desc": "Azure DevOps personal access token", "required": true, "secret": true },
        { "key": "AZURE_DEVOPS_ORG", "desc": "Azure DevOps organization URL", "required": true }
      ],
      "hint": "Create at https://dev.azure.com/{org}/_usersSettings/tokens (scope: Code Read)"
    },
    "bitbucket": {
      "label": "Bitbucket",
      "envVars": [
        { "key": "BITBUCKET_USERNAME", "desc": "Bitbucket username", "required": true },
        { "key": "BITBUCKET_APP_PASSWORD", "desc": "Bitbucket app password", "required": true, "secret": true }
      ],
      "hint": "Create app password at Bitbucket Settings → App passwords (permission: Repositories Read)"
    }
  },
  "knownEnvVars": [
    "ANTHROPIC_API_KEY", "GITHUB_TOKEN", "GITHUB_PAT",
    "AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_DEFAULT_REGION",
    "AWS_REGION", "AWS_PROFILE", "AWS_BEARER_TOKEN_BEDROCK",
    "CLAUDE_MODEL", "MODEL_ID", "MODEL", "ANTHROPIC_MODEL",
    "ANTHROPIC_DEFAULT_OPUS_MODEL", "ANTHROPIC_DEFAULT_SONNET_MODEL", "ANTHROPIC_DEFAULT_HAIKU_MODEL",
    "ANTHROPIC_SMALL_FAST_MODEL", "ANTHROPIC_BASE_URL",
    "CLAUDE_CODE_USE_BEDROCK",
    "TEMPORAL_SERVER_URL", "DYNAMODB_TABLE_NAME",
    "API_BEARER_TOKEN"
  ]
}
